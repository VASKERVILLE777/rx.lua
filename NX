local function CreatePlayerTag()
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NX_Tag"
    billboard.Size = UDim2.new(0, IS_ADMIN_USER and 220 or 180, 0, IS_ADMIN_USER and 55 or 45)
    billboard.StudsOffset = Vector3.new(0, IS_ADMIN_USER and 4.2 or 3.5, 0)
    billboard.Parent = player.Character and player.Character:FindFirstChild("Head") or game.Workspace
    billboard.AlwaysOnTop = true
    
    local frame = Instance.new("Frame", billboard)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = IS_ADMIN_USER and Color3.fromRGB(20, 0, 0) or Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = IS_ADMIN_USER and 0.1 or 0.2
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, IS_ADMIN_USER and 12 or 10)
    
    local stroke1 = Instance.new("UIStroke", frame)
    stroke1.Color = IS_ADMIN_USER and Gold or NeonGreen
    stroke1.Thickness = IS_ADMIN_USER and 3 or 2.5
    
    local text = Instance.new("TextLabel", frame)
    text.Size = UDim2.new(1, -16, 1, 0)
    text.Position = UDim2.new(0, 8, 0, 0)
    text.BackgroundTransparency = 1
    text.Text = IS_ADMIN_USER and "NX ADMIN" or "NX User"
    text.TextColor3 = IS_ADMIN_USER and Gold or NeonGreen
    text.Font = IS_ADMIN_USER and Enum.Font.GothamBlack or Enum.Font.GothamBold
    text.TextSize = IS_ADMIN_USER and 22 or 16
    text.TextStrokeTransparency = 0
    text.TextStrokeColor3 = Color3.new(0, 0, 0)
    text.TextScaled = true
    
    -- Efecto especial SOLO para ADMIN
    if IS_ADMIN_USER then
        local glow = Instance.new("UIStroke", frame)
        glow.Color = NeonGreen
        glow.Thickness = 1.8
        glow.Transparency = 0.4
        
        task.spawn(function()
            while billboard.Parent do
                TweenService:Create(glow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Transparency = 0}):Play()
                task.wait(1.2)
            end
        end)
    end
    
    return billboard
end

local playerTag = nil
local function UpdatePlayerTag()
    if playerTag then playerTag:Destroy() end
    if player.Character and player.Character:FindFirstChild("Head") then
        playerTag = CreatePlayerTag()
        playerTag.Parent = player.Character.Head
    end
end

player.CharacterAdded:Connect(function()
    task.wait(0.5)
    UpdatePlayerTag()
end)

if player.Character then UpdatePlayerTag() end

