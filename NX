local function CreateMenuButton(parent, name, pos, callback, isGreenClose)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 40); btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.BackgroundColor3 = isGreenClose and Color3.fromRGB(0, 100, 50) or Color3.fromRGB(25, 25, 25)
    btn.Text = name .. (isGreenClose and "" or ": OFF"); btn.TextColor3 = PureWhite; btn.Font = Enum.Font.GothamBold; btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    local active = false
    btn.MouseButton1Click:Connect(function()
        if isGreenClose then callback() return end
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF"); btn.TextColor3 = active and (IS_ADMIN_USER and Gold or NeonGreen) or PureWhite
        callback(active)
    end)
    return btn
end

