RunService.Heartbeat:Connect(function() if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.WalkSpeed = SpeedVal end end)
RunService.Stepped:Connect(function()
    if player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                if noclipActive then v.CanCollide = false end
                if antiAnchorActive and v.Anchored then v.Anchored = false end
                if antiFlingActive then v.RotVelocity = Vector3.new(0,0,0) end
            end
        end
    end
end)

local function AddESP(plr)
    local h = Instance.new("Highlight", ScreenGui); h.FillColor = NeonGreen
    RunService.RenderStepped:Connect(function()
        if espActive and plr.Character and plr ~= player then h.Adornee = plr.Character; h.Enabled = true else h.Enabled = false end
    end)
end
for _, p in pairs(game.Players:GetPlayers()) do AddESP(p) end
game.Players.PlayerAdded:Connect(AddESP)

