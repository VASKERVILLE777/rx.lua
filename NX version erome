-- ========== LÓGICA EN TIEMPO REAL (TECLAS, NOCLIP, ETC.) ==========

local function getSmartTPPosition()
    local char = getChar()
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local mouse = player:GetMouse()
    local rayOrigin = camera.CFrame.Position
    local mousePos = mouse.Hit.Position
    local rayDirection = (mousePos - rayOrigin).Unit * 5000
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {char}
    local rayResult = workspace:Raycast(rayOrigin, rayDirection, rayParams)
    if rayResult then
        return rayResult.Position + Vector3.new(0, 4, 0)
    else
        return rayOrigin + rayDirection
    end
end

uis.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F and tpActive and not teleportCD then
        teleportCD = true
        local char = getChar()
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            local targetPos = getSmartTPPosition()
            if targetPos then
                root.CFrame = CFrame.new(targetPos)
                root.Velocity = Vector3.zero
                root.AssemblyLinearVelocity = Vector3.zero
                Notify("TP", "🌀 Teletransportado", 1)
            end
        end
        task.wait(0.15)
        teleportCD = false
    end
end)

uis.JumpRequest:Connect(function()
    if infJumpActive then
        local char = getChar()
        local hum = char and char:FindFirstChild("Humanoid")
        if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

rs.Stepped:Connect(function()
    local char = getChar()
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if noclipActive then part.CanCollide = false end
            if antiAnchorActive then part.Anchored = false end
            if antiFlingActive then
                part.Velocity = Vector3.zero
                part.RotVelocity = Vector3.zero
            end
        end
    end
end)

rs.Heartbeat:Connect(function()
    local char = getChar()
    local hum = char and char:FindFirstChild("Humanoid")
    if antiFallActive and not antiFallCD and char and hum then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root.Velocity.Y < -20 then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {char}
            rayParams.FilterType = Enum.RaycastFilterType.Blacklist
            local rayResult = workspace:Raycast(root.Position, Vector3.new(0, -12, 0), rayParams)
            if rayResult and rayResult.Distance < 3 then
                hum.PlatformStand = true
                root.Velocity = Vector3.new(root.Velocity.X, 0, root.Velocity.Z)
                hum:ChangeState(Enum.HumanoidStateType.Landed)
                task.wait(0.05)
                hum.PlatformStand = false
                antiFallCD = true
                task.wait(0.3)
                antiFallCD = false
            end
        end
    end
end)

