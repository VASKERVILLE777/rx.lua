-- ========== FUNCIONES DE DIBUJO (MODIFICADAS PARA INCLUIR BOX) ==========
local function safeCreateLine()
    if not DrawingSupported then return nil end
    local success, line = pcall(function() return DrawingLib.new("Line") end)
    return success and line or nil
end

local function safeCreateSquare()
    if not DrawingSupported then return nil end
    local success, sq = pcall(function() return DrawingLib.new("Square") end)
    return success and sq or nil
end

-- Actualiza o crea los objetos de dibujo para un jugador según los toggles activos
local function updateDrawingsForPlayer(plr)
    if plr == player then return end
    local drawings = espDrawings[plr] or {}
    espDrawings[plr] = drawings

    -- Hitbox Vertical
    if espHitbox then
        if not drawings.verticalLine then
            local line = safeCreateLine()
            if line then
                drawings.verticalLine = line
                line.Color = Color3.fromRGB(0, 255, 156)
                line.Thickness = 2
                line.Transparency = 0.6
                line.Visible = true
            end
        end
    else
        if drawings.verticalLine then
            pcall(function() drawings.verticalLine:Remove() end)
            drawings.verticalLine = nil
        end
    end

    -- Tracer básico
    if espTracer then
        if not drawings.tracer then
            local line = safeCreateLine()
            if line then
                drawings.tracer = line
                line.Color = Color3.fromRGB(0, 255, 156)
                line.Thickness = 1.5
                line.Transparency = 0.5
                line.Visible = true
            end
        end
    else
        if drawings.tracer then
            pcall(function() drawings.tracer:Remove() end)
            drawings.tracer = nil
        end
    end

    -- Box ESP (NUEVO)
    if espBox then
        if not drawings.box then
            local box = safeCreateSquare()
            if box then
                drawings.box = box
                box.Color = espBoxColor
                box.Thickness = 2
                box.Filled = false
                box.Visible = false -- Se hará visible en update
            end
        else
            -- Actualizar color por si cambió
            drawings.box.Color = espBoxColor
        end
    else
        if drawings.box then
            pcall(function() drawings.box:Remove() end)
            drawings.box = nil
        end
    end
end

local function applyVisualsToAll()
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player then
            updateDrawingsForPlayer(plr)
        end
    end
end

local function clearDrawingsForPlayer(plr)
    local drawings = espDrawings[plr]
    if drawings then
        for _, obj in pairs(drawings) do
            pcall(function() obj:Remove() end)
        end
        espDrawings[plr] = nil
    end
end

-- ========== ACTUALIZACIÓN EN TIEMPO REAL (RenderStepped) ==========
local function updateESPVisuals()
    if not DrawingSupported then return end
    local viewportSize = camera.ViewportSize
    local centerScreen = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)

    for plr, drawings in pairs(espDrawings) do
        local char = plr.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") then
            local root = char.HumanoidRootPart
            local hum = char.Humanoid
            local head = char.Head
            local headPos = head.Position
            local feetPos = root.Position - Vector3.new(0, hum.HipHeight or 2, 0)

            local headScreen, onScreenHead = camera:WorldToViewportPoint(headPos)
            local feetScreen, onScreenFeet = camera:WorldToViewportPoint(feetPos)
            local isOnScreen = onScreenHead and onScreenFeet

            -- Hitbox vertical
            if drawings.verticalLine then
                if isOnScreen then
                    pcall(function()
                        drawings.verticalLine.From = Vector2.new(headScreen.X, headScreen.Y)
                        drawings.verticalLine.To = Vector2.new(feetScreen.X, feetScreen.Y)
                        drawings.verticalLine.Visible = true
                    end)
                else
                    pcall(function() drawings.verticalLine.Visible = false end)
                end
            end

            -- Tracer básico
            if drawings.tracer then
                if isOnScreen then
                    pcall(function()
                        drawings.tracer.From = centerScreen
                        drawings.tracer.To = Vector2.new(feetScreen.X, feetScreen.Y)
                        drawings.tracer.Visible = true
                    end)
                else
                    pcall(function() drawings.tracer.Visible = false end)
                end
            end

            -- Box ESP (NUEVO)
            if drawings.box then
                if isOnScreen then
                    local distance = (camera.CFrame.Position - headPos).Magnitude
                    local scale = 100 / math.max(distance, 1)
                    local boxWidth = 45 * scale
                    local boxHeight = 80 * scale
                    pcall(function()
                        drawings.box.Position = Vector2.new(headScreen.X - boxWidth/2, headScreen.Y - boxHeight/2)
                        drawings.box.Size = Vector2.new(boxWidth, boxHeight)
                        drawings.box.Visible = true
                    end)
                else
                    pcall(function() drawings.box.Visible = false end)
                end
            end
        else
            -- Si no hay personaje, ocultar todo
            if drawings.verticalLine then pcall(function() drawings.verticalLine.Visible = false end) end
            if drawings.tracer then pcall(function() drawings.tracer.Visible = false end) end
            if drawings.box then pcall(function() drawings.box.Visible = false end) end
        end
    end
end

-- ========== FUNCIONES PARA ESP HIGHLIGHT (sin cambios) ==========
local function createESPForPlayer(targetPlayer)
    if targetPlayer == player then return end
    if espHighlights[targetPlayer] then return end
    local char = targetPlayer.Character
    if not char then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(0, 255, 156)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.Adornee = char
    highlight.Parent = game:GetService("CoreGui")
    espHighlights[targetPlayer] = highlight
end

local function removeESPForPlayer(targetPlayer)
    local hl = espHighlights[targetPlayer]
    if hl then hl:Destroy(); espHighlights[targetPlayer] = nil end
end

-- ========== NOTIFICACIONES Y SERVER HOP (sin cambios) ==========
local function Notify(title, message, duration)
    duration = duration or 2.5
    Rayfield:Notify({
        Title = title,
        Content = message,
        Duration = duration,
        Image = nil,
        Actions = {
            Ignore = {
                Name = "Entendido",
                Callback = function() end
            },
        },
    })
end

local function serverHop(criteria)
    Notify("Server Hop", "🔎 Buscando servidores...", 2)
    local HttpService = game:GetService("HttpService")
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=" .. (criteria == "ping" and "Asc" or "Desc") .. "&limit=100"
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if not success or not result or #result.data == 0 then
        Notify("Error", "❌ No se encontraron servidores.", 2.5)
        return
    end
    local servers = result.data
    local targetServer = nil
    for _, server in ipairs(servers) do
        if server.id ~= game.JobId then
            targetServer = server
            break
        end
    end
    if not targetServer then
        Notify("Error", "❌ No se encontraron otros servidores.", 2.5)
        return
    end
    local msg = (criteria == "ping" and "📶 Conectando al servidor con mejor ping..." or "👤 Conectando al servidor con menos jugadores...")
    Notify("Server Hop", msg, 2)
    task.wait(0.5)
    pcall(function()
        teleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, player)
    end)
end

